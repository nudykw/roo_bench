# Server configuration (supports Ollama and llama.cpp server)
# Copy this file to .env and update with your values

# Backend type: ollama or llama_cpp
ROO_BENCH_BACKEND_TYPE=ollama

# Server URL (default: http://localhost:11434 for Ollama, http://localhost:8080 for llama.cpp)
OLLAMA_URL=http://localhost:11434

# Server port (default: 11434)
OLLAMA_PORT=11434

# API key for authentication (optional)
OLLAMA_API_KEY=

# Connection timeout in seconds (default: 300)
OLLAMA_TIMEOUT=300
