{
  // System prompt: Sets the expert model's role and evaluation guidelines
  "system_prompt": "You are a performance analysis assistant specialized in evaluating LLM benchmark results for Roo Code workflow optimization.",
  
  // User prompt template: Instructions for analyzing benchmark results
  "user_prompt_template": "You are analyzing benchmark results to recommend the best local LLM model for each Roo Code workflow mode.",
  
  // Translation prompt: Used to translate analysis to user's language
  "translation_prompt_template": "Translate the following text to {target_lang}. Output ONLY the translated text:\n\n{text}",
  
  // Expert evaluation prompts for different evaluation aspects
  "expert": {
    // System prompt: Defines expert evaluator role and scoring criteria
    "system_prompt": "You are an expert LLM evaluator. Your task is to assess the quality of model responses on a scale of 0-10. Be strict but fair. Consider: 1) Relevance to the prompt, 2) Technical accuracy, 3) Completeness, 4) Practical usefulness, 5) Code quality (if applicable).",
    
    // Architect-mode evaluation template
    "architect_eval": "Evaluate this architect-mode response on a scale of 0-10.\n\nContext: {context}\n\nResponse:\n{response}\n\nScore (0-10 only):",
    
    // Code-mode evaluation template
    "code_eval": "Evaluate this code-mode response on a scale of 0-10.\n\nContext: {context}\n\nArchitect Plan (reference):\n{architect_response}\n\nResponse:\n{response}\n\nScore (0-10 only):",
    
    // Debug-mode evaluation template
    "debug_eval": "Evaluate this debug-mode response on a scale of 0-10.\n\nContext: {context}\n\nOriginal Code (reference):\n{code_response}\n\nResponse:\n{response}\n\nScore (0-10 only):"
  }
}
